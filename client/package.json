{
  "name": "@freightpilot/client",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "gen:api": "openapi-typescript ../contracts/rates.openapi.yaml -o src/api/rates.gen.ts && openapi-typescript ../contracts/booking.openapi.yaml -o src/api/booking.gen.ts && openapi-typescript ../contracts/agent.openapi.yaml -o src/api/agent.gen.ts",
    "e2e": "playwright test"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.62.7",
    "openapi-fetch": "^0.13.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.49.1",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.17.0",
    "jsdom": "^25.0.1",
    "openapi-typescript": "^7.4.4",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.19.1",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}

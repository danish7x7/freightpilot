# FreightPilot environment — copy to `.env` and fill in.
# `.env` is gitignored; NEVER commit real keys. docker-compose reads this file
# automatically for variable substitution. Every value below has a working dev
# default baked into docker-compose.yml, so `make up` works on a fresh clone
# with no .env at all — you only need this file to override creds or add LLM keys.
#
# NOTE ON CREDENTIAL SCOPING (hard architecture rule):
#   Each service is handed ONLY its own database password. agent-service reaches
#   rates/booking over REST (RATES_SERVICE_URL / BOOKING_SERVICE_URL) and is NEVER
#   given RATES_DB_PASSWORD or BOOKING_DB_PASSWORD. Keep it that way.

# ---- Per-service database passwords (dev defaults shown) --------------------
RATES_DB_PASSWORD=rates_dev
BOOKING_DB_PASSWORD=booking_dev
AGENT_DB_PASSWORD=agent_dev

# ---- LLM provider keys (not used until L5; all free tiers, see MASTER_PLAN §0.1)
# Ordered fallback chain the agent's provider router walks (primary first).
LLM_CHAIN=gemini:gemini-2.5-flash,groq:llama-3.3-70b-versatile
GEMINI_API_KEY=
GROQ_API_KEY=
CEREBRAS_API_KEY=
# GITHUB_TOKEN is provided automatically in CI; set locally only if using GitHub Models.
GITHUB_TOKEN=

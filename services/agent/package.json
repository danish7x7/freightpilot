{
  "name": "@freightpilot/agent-service",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "test": "vitest run",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "record:fixtures": "RECORD_FIXTURES=1 tsx scripts/record-fixtures.ts",
    "gen:api": "openapi-typescript ../../contracts/rates.openapi.yaml -o src/api/rates.gen.ts && openapi-typescript ../../contracts/booking.openapi.yaml -o src/api/booking.gen.ts"
  },
  "dependencies": {
    "fastify": "^5.2.1",
    "openapi-fetch": "^0.13.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.5",
    "eslint": "^9.17.0",
    "openapi-typescript": "^7.4.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.19.1",
    "undici": "^6.21.0",
    "vitest": "^2.1.8"
  }
}

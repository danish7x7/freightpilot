# agent-service env (on-disk path services/agent; "agent-service" is the logical name).
# Copy to services/agent/.env and fill in real keys. .env is gitignored — never commit keys.
#
# Downstream services (agent-phase L2, §2.2). The agent reaches rates/booking ONLY via these
# public REST origins — never their databases. Injected by compose (docker-compose.yml).
RATES_SERVICE_URL=http://rates-service:8080
BOOKING_SERVICE_URL=http://booking-service:8081

# LLM adapter (agent-phase L1 / global L5, MASTER_PLAN §6.1).

# Ordered fallback chain as provider:model pairs (same format as the root .env.example).
# Router tries left-to-right, falling back ONLY on 429 / 5xx / timeout / network.
# Known providers: gemini (native), groq + cerebras (OpenAI-compatible).
LLM_CHAIN=gemini:gemini-2.5-flash,groq:llama-3.3-70b-versatile,cerebras:llama-3.3-70b

# Provider API keys (free tiers). Leave blank here; set real values in .env.
GEMINI_API_KEY=
GROQ_API_KEY=
CEREBRAS_API_KEY=

# Per-provider request pacing (requests/min), sized to each free tier. Optional —
# defaults: gemini 10, groq 30, cerebras 30.
GEMINI_RPM=10
GROQ_RPM=30
CEREBRAS_RPM=30

# Per-request transport timeout in ms; a timeout triggers fallback. Optional (default 8000).
LLM_TIMEOUT_MS=8000
